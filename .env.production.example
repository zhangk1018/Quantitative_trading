# ============================================
# .env.production.example - 量化交易系统生产环境变量模板
# ============================================
# 用法:
#   1. cp .env.production.example .env.production
#   2. 修改密码和密钥（不要提交到 git）
#   3. docker compose --env-file .env.production up -d
# ============================================

# ---- PostgreSQL 数据库（必须）----
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=quant_trading
PG_USER=quant_user
# 生成强密码: openssl rand -base64 32
PG_PASSWORD=CHANGE_ME_PLEASE_USE_OPENSSL_RAND_BASE64_32
# 管理员邮箱（pgAdmin 使用，可选）
PGADMIN_EMAIL=admin@quant.local
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# ---- 外部数据源 ----
# Tushare Token（https://tushare.pro 注册获取）
# 留空则使用 PyWenCai/Baostock 备用源
TUSHARE_TOKEN=

# ---- 服务配置 ----
HTTP_PORT=80
LOG_LEVEL=info
# CORS 允许的来源（多来源用逗号分隔；同域部署可留空）
CORS_ORIGINS=http://localhost,https://yourdomain.com

# ---- 业务配置 ----
# 默认用户 ID（自选股/策略前缀）
DEFAULT_USER_ID=default
# K 线数据保留天数（超过则归档）
KLINE_RETENTION_DAYS=3650

# ---- 可选：监控告警 ----
# SENTRY_DSN=
# ALIYUN_SLS_ENDPOINT=
# ALIYUN_SLS_PROJECT=

# ---- 镜像版本（docker compose build 时使用）----
BACKEND_IMAGE_TAG=1.0.0
FRONTEND_IMAGE_TAG=1.0.0
